<IfModule mod_rewrite.c>
RewriteEngine On

# Block access to sensitive files
<FilesMatch "\.(env|log|sql|bak|backup|old|tmp|temp|cache)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to PHP files in uploads directory
<FilesMatch "\.php$">
    <If "%{REQUEST_URI} =~ m#^/public/assets/#">
        Order allow,deny
        Deny from all
    </If>
</FilesMatch>

# Block directory traversal attempts
RewriteCond %{QUERY_STRING} \.\./
RewriteRule ^(.*)$ - [F,L]

RewriteCond %{QUERY_STRING} \.\.\%2F
RewriteRule ^(.*)$ - [F,L]

# Block shell injection attempts
RewriteCond %{QUERY_STRING} (exec|system|shell_exec|passthru|eval|base64_decode) [NC]
RewriteRule ^(.*)$ - [F,L]

RewriteRule ^(.*)$ public/$1 [L]
</IfModule>