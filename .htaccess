<IfModule mod_rewrite.c>
RewriteEngine On

# Block sensitive files
<FilesMatch "\.(env|log|sql|bak|backup)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block directory traversal - only in query string
RewriteCond %{QUERY_STRING} \.\./
RewriteRule ^(.*)$ - [F,L]

# Block shell injection - only dangerous combinations
RewriteCond %{QUERY_STRING} (exec\(|system\(|shell_exec\(|passthru\(|eval\() [NC]
RewriteRule ^(.*)$ - [F,L]

# Block SQL injection - only dangerous patterns
RewriteCond %{QUERY_STRING} (union\s+select|insert\s+into|delete\s+from) [NC]
RewriteRule ^(.*)$ - [F,L]

# Block XSS - only script tags
RewriteCond %{QUERY_STRING} <script [NC]
RewriteRule ^(.*)$ - [F,L]

# Redirect to public folder
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options SAMEORIGIN
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>